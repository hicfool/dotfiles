set $c0 #151515
set $c1 #505050
set $c2 #EEEEEE

output HDMI-A-1 {
    mode 1920x1080@100.000Hz
    bg $c0 solid_color
}

input type:pointer {
    accel_profile "flat"
    pointer_accel 0.5
}

input type:keyboard xkb_layout pt

gaps inner 16
for_window [class=".*"] floating enable
for_window [class=".*"] border pixel 2
floating_modifier Mod4 normal

exec --no-startup-id /usr/lib/xdg-desktop-portal -r
exec --no-startup-id /usr/lib/xdg-desktop-portal-wlr

bindsym Mod4+q kill
bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right
bindsym Mod4+Shift+h move left  20px
bindsym Mod4+Shift+j move down  20px
bindsym Mod4+Shift+k move up    20px
bindsym Mod4+Shift+l move right 20px
bindsym Mod4+1 workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+Shift+1 move container to workspace number 1
bindsym Mod4+Shift+2 move container to workspace number 2
bindsym Mod4+Shift+3 move container to workspace number 3
bindsym Mod4+Shift+4 move container to workspace number 4
bindsym Mod4+Shift+5 move container to workspace number 5
bindsym Mod4+x splith
bindsym Mod4+y splitv
bindsym Mod4+e layout toggle split
bindsym Mod4+f fullscreen
bindsym Mod4+s floating toggle
bindsym Mod4+Space focus mode_toggle
bindsym Mod4+r mode "resize"
bindsym Mod4+Return exec foot
bindsym Mod4+d exec wmenu-run -f "Noto Sans Mono 11" -N "$c0" -n "$c2" -s "$c0" -S "$c2"
bindsym Print exec ~/scripts/prnt
bindsym Shift+Print exec ~/scripts/prnt -s
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -10%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +10%
bindsym --locked XF86MonBrightnessDown exec ddcutil setvcp 10 - 10
bindsym --locked XF86MonBrightnessUp exec ddcutil setvcp 10 + 10

mode "resize" {
    bindsym h  resize shrink width 20px
    bindsym l resize grow width 20px
    bindsym k resize shrink height 20px
    bindsym j resize grow height 20px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# class                 brdr    bg    txt    indi    chld_brdr
client.focused          $c2     $c0   $c2    $c2     $c2
client.focused_inactive $c1     $c0   $c1    $c1     $c1
client.unfocused        $c1     $c0   $c1    $c1     $c1
client.urgent           $c1     $c0   $c1    $c1     $c1
client.placeholder      $c1     $c0   $c1    $c1     $c1
