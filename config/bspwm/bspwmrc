#!/bin/sh
. ~/.theme
envsubst < ~/.Xresources > /tmp/Xresources &
xrdb /tmp/Xresources &
killall sxhkd; sxhkd &
xsetroot -solid $C0 &
xsetroot -cursor_name left_ptr &
pkill -9 lemonbar; ~/Bin/bar &
sleep 0.15; xdo above -t $(xdo id -n root) $(xdo id -n lemonbar) &

bspc config active_border_color     $C1
bspc config focused_border_color    $C1
bspc config normal_border_color     $C2
bspc config presel_feedback_color   $C2

bspc config bottom_padding          1
bspc config left_padding            1
bspc config right_padding           1
bspc config window_gap             -1

bspc config border_width            1

bspc config split_ratio             1
bspc config borderless_monocle      false
bspc config gapless_monocle         false
bspc config pointer_motion_interval 5

bspc monitor -d                     1 2 3 4
